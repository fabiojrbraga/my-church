# ─── Banco de Dados ───────────────────────────
DATABASE_URL=postgresql://mychurch:mychurch_secret@localhost:5432/mychurch
POSTGRES_USER=mychurch
POSTGRES_PASSWORD=mychurch_secret
POSTGRES_DB=mychurch

# ─── API ──────────────────────────────────────
NODE_ENV=development
PORT=3333
HOST=0.0.0.0

# GERE COM: openssl rand -base64 32
JWT_SECRET=TROQUE_POR_UM_SEGREDO_FORTE_DE_32_CARACTERES
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# ─── Redis ────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── CORS ─────────────────────────────────────
# Produção: URL do seu domínio
CORS_ORIGIN=http://localhost:5173

# ─── Storage ──────────────────────────────────
STORAGE_PROVIDER=local
# Para S3/MinIO:
# STORAGE_PROVIDER=minio
# STORAGE_BUCKET=mychurch
# S3_ENDPOINT=http://minio:9000
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_REGION=us-east-1

# ─── E-mail ───────────────────────────────────
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM="MyChurch <noreply@mychurch.com.br>"
